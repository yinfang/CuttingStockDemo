<Window x:Class="CuttingStockProblem.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CuttingStockProblem.Views"
        mc:Ignorable="d"
        Title="一维下料问题求解器" Height="600" Width="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="文件">
                <MenuItem Header="新建" />
                <MenuItem Header="打开" />
                <MenuItem Header="保存" />
                <Separator />
                <MenuItem Header="导出到Excel" />
                <Separator />
                <MenuItem Header="退出" />
            </MenuItem>
            <MenuItem Header="工具">
                <MenuItem Header="设置" />
                <MenuItem Header="算法参数" />
            </MenuItem>
            <MenuItem Header="帮助">
                <MenuItem Header="关于" />
            </MenuItem>
        </Menu>

        <TabControl Grid.Row="1" Margin="10">
            <TabItem Header="数据输入">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <GroupBox Grid.Column="0" Header="原材料" Margin="5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <DataGrid Grid.Row="1" Name="StockMaterialsGrid" AutoGenerateColumns="False"
                                      CanUserAddRows="True" Margin="5">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="长度" Binding="{Binding Length}" Width="*"/>
                                    <DataGridTextColumn Header="数量" Binding="{Binding Quantity}" Width="*"/>
                                    <DataGridTextColumn Header="成本" Binding="{Binding Cost}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                                <Button Content="添加原材料" Width="100" Margin="5"/>
                                <Button Content="删除原材料" Width="100" Margin="5"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <GroupBox Grid.Column="1" Header="切割项目" Margin="5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <DataGrid Grid.Row="1" Name="CuttingItemsGrid" AutoGenerateColumns="False"
                                      CanUserAddRows="True" Margin="5">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="长度" Binding="{Binding Length}" Width="*"/>
                                    <DataGridTextColumn Header="数量" Binding="{Binding Quantity}" Width="*"/>
                                    <DataGridTextColumn Header="需求" Binding="{Binding Demand}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                                <Button Content="添加项目" Width="100" Margin="5"/>
                                <Button Content="删除项目" Width="100" Margin="5"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="算法设置">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="种群大小:" Margin="5"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="100" Width="100" HorizontalAlignment="Left" Margin="5"/>

                    <Label Grid.Row="1" Grid.Column="0" Content="最大迭代次数:" Margin="5"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="500" Width="100" HorizontalAlignment="Left" Margin="5"/>

                    <Label Grid.Row="2" Grid.Column="0" Content="交叉率:" Margin="5"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="0.8" Width="100" HorizontalAlignment="Left" Margin="5"/>

                    <Label Grid.Row="3" Grid.Column="0" Content="变异率:" Margin="5"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="0.1" Width="100" HorizontalAlignment="Left" Margin="5"/>

                    <Label Grid.Row="4" Grid.Column="0" Content="损耗值:" Margin="5"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Text="0.1" Width="100" HorizontalAlignment="Left" Margin="5"/>

                    <Button Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Content="运行算法"
                            Width="150" Height="30" Margin="5" HorizontalAlignment="Left"/>
                </Grid>
            </TabItem>

            <TabItem Header="结果展示">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="解决方案摘要" Margin="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="5">
                                <TextBlock Text="总模式数:" FontWeight="Bold"/>
                                <TextBlock Text="0" Name="TotalPatternsText"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="5">
                                <TextBlock Text="总浪费:" FontWeight="Bold"/>
                                <TextBlock Text="0" Name="TotalWasteText"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="5">
                                <TextBlock Text="效率:" FontWeight="Bold"/>
                                <TextBlock Text="0%" Name="EfficiencyText"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3" Margin="5">
                                <TextBlock Text="总成本:" FontWeight="Bold"/>
                                <TextBlock Text="¥0" Name="TotalCostText"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <DataGrid Grid.Row="1" Name="ResultsGrid" AutoGenerateColumns="False" Margin="5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="模式编号" Binding="{Binding PatternNumber}" Width="*"/>
                            <DataGridTextColumn Header="原材料长度" Binding="{Binding StockLength}" Width="*"/>
                            <DataGridTextColumn Header="项目数量" Binding="{Binding ItemsCount}" Width="*"/>
                            <DataGridTextColumn Header="浪费量" Binding="{Binding Waste}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                        <Button Content="导出到Excel" Width="120" Height="30" Margin="5"/>
                        <Button Content="打印解决方案" Width="120" Height="30" Margin="5"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <StatusBar Grid.Row="2">
            <StatusBarItem Content="就绪" Name="StatusBar"/>
        </StatusBar>
    </Grid>
</Window>